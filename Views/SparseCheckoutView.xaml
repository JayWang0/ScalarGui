<UserControl x:Class="ScalarGui.Views.SparseCheckoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ScalarGui.ViewModels"
             xmlns:conv="clr-namespace:ScalarGui.Converters"
             xmlns:loc="clr-namespace:ScalarGui.Localization"
             d:DataContext="{d:DesignInstance Type=vm:SparseCheckoutViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{loc:Str Sparse_Title}" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding RepoPath, StringFormat='Repo: {0}'}" Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main Content: Tree + Patterns + Progress -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Directory Tree -->
            <GroupBox Grid.Column="0" Header="{loc:Str Sparse_RepoDirs}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TreeView x:Name="DirTree" Grid.Row="0" ItemsSource="{Binding TreeRoots}"
                              TreeViewItem.Expanded="TreeViewItem_Expanded"
                              SelectedItemChanged="DirTree_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁 " FontSize="14"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{loc:Str Sparse_Loading}" Foreground="Gray"
                                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    <Button Grid.Row="1" Content="{loc:Str Sparse_AddSelected}"
                            Command="{Binding AddSelectedDirectoryCommand}"
                            IsEnabled="{Binding IsWorking, Converter={StaticResource InverseBool}}"
                            Padding="8,6" Margin="0,4,0,0"/>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"/>

            <!-- Right: Current Patterns + Progress -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Current sparse-checkout patterns -->
                <GroupBox Grid.Row="0" Header="{loc:Str Sparse_CurrentDirs}" MaxHeight="200">
                    <ListBox ItemsSource="{Binding CurrentPatterns}" FontFamily="Consolas" FontSize="12"
                             BorderThickness="0"/>
                </GroupBox>

                <!-- Progress Panel -->
                <GroupBox Grid.Row="1" Header="{loc:Str Sparse_Progress}" Margin="0,8,0,0">
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding OverallProgress}" Minimum="0" Maximum="100"
                                     Height="20" Margin="0,0,0,4"/>
                        <WrapPanel Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <TextBlock Text="{Binding [Sparse_Done], Source={x:Static loc:TranslationSource.Instance}}"/>
                                <TextBlock Text="{Binding DoneCount, Mode=OneWay}" FontWeight="Bold" Foreground="Green"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <TextBlock Text="{Binding [Sparse_Failed], Source={x:Static loc:TranslationSource.Instance}}"/>
                                <TextBlock Text="{Binding FailedCount, Mode=OneWay}" FontWeight="Bold" Foreground="Red"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding [Sparse_Total], Source={x:Static loc:TranslationSource.Instance}}"/>
                                <TextBlock Text="{Binding TotalCount, Mode=OneWay}" FontWeight="Bold"/>
                            </StackPanel>
                        </WrapPanel>
                        <TextBlock Text="{Binding CurrentSubDir, StringFormat='Current: {0}'}" Foreground="Gray"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="{loc:Str Sparse_Pause}" Command="{Binding PauseCommand}"
                                    Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}"
                                    Padding="8,4" Margin="0,0,8,0"/>
                            <Button Content="{loc:Str Sparse_RetryFailed}" Command="{Binding RetryFailedCommand}"
                                    Padding="8,4" Margin="0,0,8,0"/>
                            <Button Content="{loc:Str Sparse_Refresh}" Command="{Binding RefreshCurrentPatternsCommand}"
                                    Padding="8,4"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Previous Tasks (for resume) -->
                <GroupBox Grid.Row="2" Header="{loc:Str Sparse_PreviousTasks}" Margin="0,8,0,0" MaxHeight="150">
                    <ListBox ItemsSource="{Binding PreviousTasks}" FontSize="12" BorderThickness="0"
                             MouseDoubleClick="PreviousTask_DoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TargetDirectory}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DoneCount, StringFormat='({0}'}" Foreground="Green"/>
                                    <TextBlock Text="{Binding TotalCount, StringFormat='/{0})'}" Foreground="Gray"/>
                                    <TextBlock Text="{Binding OverallStatus}" Margin="8,0,0,0"
                                               Foreground="{Binding OverallStatus, Converter={StaticResource StatusToColor}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0"/>

        <!-- Log -->
        <GroupBox Grid.Row="3" Header="{loc:Str Sparse_Log}" Margin="0,8,0,0">
            <ListBox ItemsSource="{Binding LogLines}" FontFamily="Consolas" FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0"/>
        </GroupBox>
    </Grid>
</UserControl>
